.mp-debug-storage {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #1e1e1e;
}

.mp-debug-storage-main {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* 工具栏 */
.mp-debug-storage-toolbar {
  display: flex;
  align-items: center;
  height: 36px;
  padding: 0 10px;
  background: #252526;
  border-bottom: 1px solid #3c3c3c;
  flex-shrink: 0;
}

.mp-debug-storage-info {
  font-size: 11px;
  color: #999;
}

.mp-debug-storage-toolbar-spacer {
  flex: 1;
}

.mp-debug-storage-refresh {
  padding: 4px 8px;
}

.mp-debug-storage-refresh text {
  font-size: 14px;
}

/* 列表 */
.mp-debug-storage-list {
  flex: 1;
  overflow: hidden;
}

.mp-debug-storage-item {
  padding: 8px 10px;
  border-bottom: 1px solid #2d2d2d;
}

.mp-debug-storage-item-row {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}

.mp-debug-storage-item-key {
  font-size: 12px;
  color: #9cdcfe;
  font-weight: 600;
  margin-right: 8px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.mp-debug-storage-item-type {
  font-size: 10px;
  color: #666;
  flex-shrink: 0;
}

.mp-debug-storage-item-preview {
  font-size: 11px;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
  display: block;
}

/* 详情 */
.mp-debug-storage-detail {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.mp-debug-storage-detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 36px;
  padding: 0 10px;
  background: #252526;
  border-bottom: 1px solid #3c3c3c;
  flex-shrink: 0;
}

.mp-debug-storage-detail-back text {
  font-size: 12px;
  color: #3794ff;
}

.mp-debug-storage-detail-actions {
  display: flex;
}

.mp-debug-storage-detail-btn {
  margin-left: 10px;
}

.mp-debug-storage-detail-btn text {
  font-size: 12px;
  color: #3794ff;
}

.mp-debug-storage-detail-btn-danger text {
  color: #f44336;
}

.mp-debug-storage-detail-content {
  flex: 1;
  overflow: hidden;
  padding: 10px;
}

.mp-debug-storage-detail-kv {
  margin-bottom: 12px;
}

.mp-debug-storage-detail-label {
  font-size: 11px;
  color: #666;
  display: block;
  margin-bottom: 4px;
}

.mp-debug-storage-detail-value {
  font-size: 12px;
  color: #d4d4d4;
  word-break: break-all;
}

.mp-debug-storage-detail-data {
  margin-top: 12px;
}

.mp-debug-storage-code-block {
  font-size: 11px;
  color: #ce9178;
  word-break: break-all;
  font-family: monospace;
  white-space: pre-wrap;
  padding: 8px;
  background: #252526;
  border-radius: 4px;
  line-height: 1.5;
  display: block;
  margin-top: 4px;
}

/* 空状态 */
.mp-debug-storage-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120px;
}

.mp-debug-storage-empty-text {
  color: #666;
  font-size: 13px;
}
