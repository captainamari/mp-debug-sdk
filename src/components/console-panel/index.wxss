.mp-debug-console {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #1e1e1e;
}

/* 过滤栏 */
.mp-debug-console-filter {
  display: flex;
  align-items: center;
  height: 36px;
  padding: 0 8px;
  background: #252526;
  border-bottom: 1px solid #3c3c3c;
  flex-shrink: 0;
}

.mp-debug-console-filter-item {
  padding: 4px 10px;
  font-size: 12px;
  color: #999;
  border-radius: 3px;
  margin-right: 4px;
}

.mp-debug-console-filter-item.active {
  color: #fff;
  background: #0e639c;
}

.mp-debug-console-filter-spacer {
  flex: 1;
}

.mp-debug-console-clear {
  padding: 4px 8px;
}

.mp-debug-console-clear-icon {
  font-size: 14px;
}

/* 日志列表 */
.mp-debug-console-list {
  flex: 1;
  overflow: hidden;
}

/* 日志条目 */
.mp-debug-console-item {
  padding: 6px 10px;
  border-bottom: 1px solid #2d2d2d;
  font-size: 12px;
}

.mp-debug-console-item-header {
  display: flex;
  align-items: flex-start;
}

.mp-debug-console-item-type {
  margin-right: 6px;
  flex-shrink: 0;
  width: 14px;
  text-align: center;
  font-size: 12px;
}

.mp-debug-console-item-time {
  color: #666;
  font-size: 10px;
  margin-right: 8px;
  flex-shrink: 0;
  line-height: 18px;
}

.mp-debug-console-item-content {
  color: #d4d4d4;
  word-break: break-all;
  line-height: 18px;
  flex: 1;
}

/* 日志类型样式 */
.mp-debug-console-log .mp-debug-console-item-content {
  color: #d4d4d4;
}

.mp-debug-console-log .mp-debug-console-item-type {
  color: #d4d4d4;
}

.mp-debug-console-info .mp-debug-console-item-content {
  color: #3794ff;
}

.mp-debug-console-info .mp-debug-console-item-type {
  color: #3794ff;
}

.mp-debug-console-warn {
  background: rgba(255, 204, 0, 0.06);
}

.mp-debug-console-warn .mp-debug-console-item-content {
  color: #cca700;
}

.mp-debug-console-warn .mp-debug-console-item-type {
  color: #cca700;
}

.mp-debug-console-error {
  background: rgba(244, 67, 54, 0.06);
}

.mp-debug-console-error .mp-debug-console-item-content {
  color: #f44336;
}

.mp-debug-console-error .mp-debug-console-item-type {
  color: #f44336;
}

.mp-debug-console-debug .mp-debug-console-item-content {
  color: #9e9e9e;
}

/* 展开详情 */
.mp-debug-console-item-detail {
  margin-top: 6px;
  padding: 8px;
  background: #252526;
  border-radius: 4px;
}

.mp-debug-console-detail-block {
  margin-bottom: 4px;
}

.mp-debug-console-detail-type {
  color: #666;
  font-size: 10px;
  margin-right: 4px;
}

.mp-debug-console-detail-value {
  color: #ce9178;
  font-size: 12px;
  word-break: break-all;
  font-family: monospace;
}

.mp-debug-console-item-actions {
  margin-top: 6px;
  display: flex;
  justify-content: flex-end;
}

.mp-debug-console-action-btn {
  font-size: 11px;
  color: #3794ff;
  padding: 2px 8px;
  border: 1px solid #3794ff;
  border-radius: 3px;
}

/* 空状态 */
.mp-debug-console-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120px;
}

.mp-debug-console-empty-text {
  color: #666;
  font-size: 13px;
}
