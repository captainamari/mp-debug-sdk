<view class="mp-debug-network" wx:if="{{visible}}">

  <!-- 请求列表（非详情状态） -->
  <view wx:if="{{!showDetail}}" class="mp-debug-network-main">
    <!-- 顶部操作栏 -->
    <view class="mp-debug-network-toolbar">
      <text class="mp-debug-network-count">{{requests.length}} requests</text>
      <view class="mp-debug-network-toolbar-spacer"></view>
      <view class="mp-debug-network-clear" catchtap="onClear">
        <text class="mp-debug-network-clear-icon">🗑</text>
      </view>
    </view>

    <!-- 请求列表 -->
    <scroll-view
      class="mp-debug-network-list"
      scroll-y
      scroll-into-view="{{scrollToView}}"
      scroll-with-animation
      enhanced
      show-scrollbar="{{false}}"
    >
      <view
        wx:for="{{requests}}"
        wx:key="id"
        id="req-{{item.id}}"
        class="mp-debug-network-item mp-debug-network-status-{{item.statusType}}"
        data-index="{{index}}"
        catchtap="onSelectRequest"
      >
        <view class="mp-debug-network-item-row1">
          <text class="mp-debug-network-item-method">{{item.method}}</text>
          <text class="mp-debug-network-item-url">{{item.shortUrl}}</text>
        </view>
        <view class="mp-debug-network-item-row2">
          <text class="mp-debug-network-item-status mp-debug-network-code-{{item.statusType}}">{{item.statusCode}}</text>
          <text class="mp-debug-network-item-duration">{{item.durationStr}}</text>
          <text class="mp-debug-network-item-size">{{item.responseSize}}</text>
          <text class="mp-debug-network-item-time">{{item.startTimeStr}}</text>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{requests.length === 0}}" class="mp-debug-network-empty">
        <text class="mp-debug-network-empty-text">No requests yet</text>
      </view>
    </scroll-view>
  </view>

  <!-- 请求详情 -->
  <view wx:if="{{showDetail && selectedRequest}}" class="mp-debug-network-detail">
    <!-- 详情头部 -->
    <view class="mp-debug-network-detail-header">
      <view class="mp-debug-network-detail-back" catchtap="onCloseDetail">
        <text>← Back</text>
      </view>
      <view class="mp-debug-network-detail-copy" catchtap="onCopyRequest">
        <text>Copy</text>
      </view>
    </view>

    <!-- 详情 Tab -->
    <view class="mp-debug-network-detail-tabs">
      <view
        wx:for="{{detailTabs}}"
        wx:key="key"
        class="mp-debug-network-detail-tab {{detailTab === item.key ? 'active' : ''}}"
        data-tab="{{item.key}}"
        catchtap="onDetailTabChange"
      >
        <text>{{item.label}}</text>
      </view>
    </view>

    <!-- 详情内容 -->
    <scroll-view class="mp-debug-network-detail-content" scroll-y enhanced show-scrollbar="{{false}}">

      <!-- General -->
      <view wx:if="{{detailTab === 'general'}}" class="mp-debug-network-detail-section">
        <view class="mp-debug-network-kv">
          <text class="mp-debug-network-kv-key">URL</text>
          <text class="mp-debug-network-kv-value" user-select>{{selectedRequest.url}}</text>
        </view>
        <view class="mp-debug-network-kv">
          <text class="mp-debug-network-kv-key">Method</text>
          <text class="mp-debug-network-kv-value">{{selectedRequest.method}}</text>
        </view>
        <view class="mp-debug-network-kv">
          <text class="mp-debug-network-kv-key">Status</text>
          <text class="mp-debug-network-kv-value mp-debug-network-code-{{selectedRequest.statusType}}">{{selectedRequest.statusCode}}</text>
        </view>
        <view class="mp-debug-network-kv">
          <text class="mp-debug-network-kv-key">Duration</text>
          <text class="mp-debug-network-kv-value">{{selectedRequest.durationStr || 'Pending...'}}</text>
        </view>
        <view class="mp-debug-network-kv">
          <text class="mp-debug-network-kv-key">Size</text>
          <text class="mp-debug-network-kv-value">{{selectedRequest.responseSize || '-'}}</text>
        </view>
        <view wx:if="{{selectedRequest.errMsg}}" class="mp-debug-network-kv">
          <text class="mp-debug-network-kv-key">Error</text>
          <text class="mp-debug-network-kv-value mp-debug-network-code-fail" user-select>{{selectedRequest.errMsg}}</text>
        </view>
      </view>

      <!-- Request Headers -->
      <view wx:if="{{detailTab === 'reqHeaders'}}" class="mp-debug-network-detail-section">
        <view wx:if="{{selectedRequest.requestHeaderList.length === 0}}" class="mp-debug-network-detail-empty">
          <text>No request headers</text>
        </view>
        <view
          wx:for="{{selectedRequest.requestHeaderList}}"
          wx:key="key"
          class="mp-debug-network-kv"
        >
          <text class="mp-debug-network-kv-key">{{item.key}}</text>
          <text class="mp-debug-network-kv-value" user-select>{{item.value}}</text>
        </view>
      </view>

      <!-- Request Body -->
      <view wx:if="{{detailTab === 'reqBody'}}" class="mp-debug-network-detail-section">
        <view wx:if="{{!selectedRequest.requestDataFormatted}}" class="mp-debug-network-detail-empty">
          <text>No request body</text>
        </view>
        <text wx:else class="mp-debug-network-code-block" user-select>{{selectedRequest.requestDataFormatted}}</text>
      </view>

      <!-- Response -->
      <view wx:if="{{detailTab === 'response'}}" class="mp-debug-network-detail-section">
        <!-- Response Headers -->
        <view wx:if="{{selectedRequest.responseHeaderList.length > 0}}" class="mp-debug-network-resp-headers">
          <text class="mp-debug-network-section-title">Response Headers</text>
          <view
            wx:for="{{selectedRequest.responseHeaderList}}"
            wx:key="key"
            class="mp-debug-network-kv"
          >
            <text class="mp-debug-network-kv-key">{{item.key}}</text>
            <text class="mp-debug-network-kv-value" user-select>{{item.value}}</text>
          </view>
        </view>
        <!-- Response Body -->
        <view class="mp-debug-network-resp-body">
          <text class="mp-debug-network-section-title">Response Body</text>
          <view wx:if="{{!selectedRequest.responseDataFormatted}}" class="mp-debug-network-detail-empty">
            <text>{{selectedRequest.status === 'pending' ? 'Waiting for response...' : 'No response data'}}</text>
          </view>
          <text wx:else class="mp-debug-network-code-block" user-select>{{selectedRequest.responseDataFormatted}}</text>
        </view>
      </view>

    </scroll-view>
  </view>
</view>
