<movable-area wx:if="{{visible}}" class="mp-debug-float-area" style="width:{{areaWidth}}px;height:{{areaHeight}}px;">
  <movable-view
    class="mp-debug-float-btn"
    direction="all"
    x="{{x}}"
    y="{{y}}"
    damping="40"
    friction="5"
    style="width:{{btnSize}}px;height:{{btnSize}}px;"
    catchtap="onTap"
  >
    <view class="mp-debug-float-inner">
      <text class="mp-debug-float-icon">🛠</text>
    </view>
    <view wx:if="{{badgeCount > 0}}" class="mp-debug-float-badge">
      <text class="mp-debug-float-badge-text">{{badgeCount > 99 ? '99+' : badgeCount}}</text>
    </view>
  </movable-view>
</movable-area>
