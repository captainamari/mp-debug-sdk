<view wx:if="{{enabled}}">
  <!-- 悬浮按钮 -->
  <float-button
    visible="{{!panelVisible}}"
    badgeCount="{{badgeCount}}"
    bind:tap="onTogglePanel"
  />

  <!-- 面板遮罩 -->
  <view
    wx:if="{{panelVisible}}"
    class="mp-debug-mask"
    catchtap="hidePanel"
  ></view>

  <!-- 主面板 -->
  <view
    wx:if="{{panelVisible}}"
    class="mp-debug-panel {{animationClass}}"
    style="height:{{panelHeight}}px;"
    catchtouchmove="onPreventTouchMove"
  >
    <!-- 面板头部 -->
    <view class="mp-debug-panel-header">
      <!-- Tab 栏 -->
      <view class="mp-debug-panel-tabs">
        <view
          wx:for="{{tabs}}"
          wx:key="key"
          class="mp-debug-panel-tab {{activeTab === item.key ? 'active' : ''}}"
          data-tab="{{item.key}}"
          catchtap="onTabChange"
        >
          <text>{{item.label}}</text>
        </view>
      </view>

      <!-- 关闭按钮 -->
      <view class="mp-debug-panel-close" catchtap="hidePanel">
        <text class="mp-debug-panel-close-icon">✕</text>
      </view>
    </view>

    <!-- 面板内容区 -->
    <view class="mp-debug-panel-body">
      <console-panel visible="{{activeTab === 'console'}}" />
      <network-panel visible="{{activeTab === 'network'}}" />
      <storage-panel visible="{{activeTab === 'storage'}}" />
    </view>
  </view>
</view>
