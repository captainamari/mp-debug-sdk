.mp-debug-network {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: #1e1e1e;
}

.mp-debug-network-main {
  display: flex;
  flex-direction: column;
  height: 100%;
}

/* 工具栏 */
.mp-debug-network-toolbar {
  display: flex;
  align-items: center;
  height: 36px;
  padding: 0 10px;
  background: #252526;
  border-bottom: 1px solid #3c3c3c;
  flex-shrink: 0;
}

.mp-debug-network-count {
  font-size: 12px;
  color: #999;
}

.mp-debug-network-toolbar-spacer {
  flex: 1;
}

.mp-debug-network-clear {
  padding: 4px 8px;
}

.mp-debug-network-clear-icon {
  font-size: 14px;
}

/* 请求列表 */
.mp-debug-network-list {
  flex: 1;
  overflow: hidden;
}

.mp-debug-network-item {
  padding: 8px 10px;
  border-bottom: 1px solid #2d2d2d;
}

.mp-debug-network-item-row1 {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}

.mp-debug-network-item-method {
  font-size: 11px;
  color: #569cd6;
  font-weight: 600;
  margin-right: 8px;
  flex-shrink: 0;
  min-width: 36px;
}

.mp-debug-network-item-url {
  font-size: 12px;
  color: #d4d4d4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.mp-debug-network-item-row2 {
  display: flex;
  align-items: center;
}

.mp-debug-network-item-status {
  font-size: 11px;
  margin-right: 10px;
  font-weight: 600;
}

.mp-debug-network-item-duration {
  font-size: 11px;
  color: #999;
  margin-right: 10px;
}

.mp-debug-network-item-size {
  font-size: 11px;
  color: #666;
  margin-right: 10px;
}

.mp-debug-network-item-time {
  font-size: 10px;
  color: #555;
  margin-left: auto;
}

/* 状态码颜色 */
.mp-debug-network-code-success {
  color: #4caf50;
}

.mp-debug-network-code-redirect {
  color: #2196f3;
}

.mp-debug-network-code-client-error {
  color: #ff9800;
}

.mp-debug-network-code-server-error {
  color: #f44336;
}

.mp-debug-network-code-pending {
  color: #999;
}

.mp-debug-network-code-fail {
  color: #f44336;
}

.mp-debug-network-code-unknown {
  color: #999;
}

/* 详情页 */
.mp-debug-network-detail {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.mp-debug-network-detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 36px;
  padding: 0 10px;
  background: #252526;
  border-bottom: 1px solid #3c3c3c;
  flex-shrink: 0;
}

.mp-debug-network-detail-back text,
.mp-debug-network-detail-copy text {
  font-size: 12px;
  color: #3794ff;
}

/* 详情 Tab */
.mp-debug-network-detail-tabs {
  display: flex;
  height: 32px;
  background: #252526;
  border-bottom: 1px solid #3c3c3c;
  flex-shrink: 0;
}

.mp-debug-network-detail-tab {
  padding: 0 12px;
  display: flex;
  align-items: center;
}

.mp-debug-network-detail-tab text {
  font-size: 11px;
  color: #999;
}

.mp-debug-network-detail-tab.active {
  border-bottom: 2px solid #0e639c;
}

.mp-debug-network-detail-tab.active text {
  color: #fff;
}

/* 详情内容 */
.mp-debug-network-detail-content {
  flex: 1;
  overflow: hidden;
}

.mp-debug-network-detail-section {
  padding: 10px;
}

.mp-debug-network-kv {
  display: flex;
  padding: 4px 0;
  border-bottom: 1px solid #2d2d2d;
}

.mp-debug-network-kv-key {
  font-size: 11px;
  color: #9cdcfe;
  width: 100px;
  flex-shrink: 0;
  word-break: break-all;
}

.mp-debug-network-kv-value {
  font-size: 11px;
  color: #d4d4d4;
  word-break: break-all;
  flex: 1;
}

.mp-debug-network-code-block {
  font-size: 11px;
  color: #ce9178;
  word-break: break-all;
  font-family: monospace;
  white-space: pre-wrap;
  padding: 8px;
  background: #252526;
  border-radius: 4px;
  line-height: 1.5;
}

.mp-debug-network-section-title {
  font-size: 12px;
  color: #fff;
  font-weight: 600;
  margin-bottom: 8px;
  display: block;
}

.mp-debug-network-resp-headers {
  margin-bottom: 16px;
}

.mp-debug-network-detail-empty {
  padding: 20px 0;
  text-align: center;
}

.mp-debug-network-detail-empty text {
  font-size: 12px;
  color: #666;
}

/* 空状态 */
.mp-debug-network-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120px;
}

.mp-debug-network-empty-text {
  color: #666;
  font-size: 13px;
}
